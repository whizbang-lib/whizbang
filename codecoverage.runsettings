<?xml version="1.0" encoding="utf-8"?>
<!--
  DEPRECATED: This file uses the coverlet/XPlat Code Coverage format.
  This project uses Microsoft.Testing.Extensions.CodeCoverage instead.

  Coverage settings have moved to: codecoverage.config
  Used via: dotnet run - - --coverage --coverage-settings codecoverage.config

  This file is retained for compatibility with tools that expect .runsettings
  (e.g., dotnet test --settings). For the Run-Tests.ps1 script, the
  codecoverage.config file is used automatically.
-->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>cobertura</Format>
          <ExcludeAssembliesWithoutSources>None</ExcludeAssembliesWithoutSources>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
