<?xml version="1.0" encoding="utf-8"?>
<!--
  Coverage settings for Microsoft.Testing.Extensions.CodeCoverage
  Used by: dotnet run [project] ... [coverage-settings] codecoverage.config

  Key settings:
  - ExcludeAssembliesWithoutSources=None: Prevents 0% coverage when PDB source paths
    don't resolve (CI builds, path mismatches, internal/generated types)
  - Format=cobertura: Standard XML coverage format for reporting tools
  - ModulePaths exclude: Skip test infrastructure, mocking, and framework assemblies

  See: https://github.com/microsoft/codecoverage/blob/main/docs/configuration.md
-->
<Configuration>
  <Format>cobertura</Format>

  <CodeCoverage>
    <!--
      ExcludeAssembliesWithoutSources: Controls whether assemblies are excluded
      from coverage when their PDB source file paths can't be resolved on disk.

      Default (MissingAll) causes 0% line-rate for classes whose source files
      appear unreachable — including internal types, async state machine classes
      (<MethodName>d__N), and compiler-generated code — even when tests execute
      all code paths. Setting to None ensures instrumentation tracks hits
      regardless of source file availability.

      Values: NotSpecified | MissingAny | MissingAll | None
    -->
    <ExcludeAssembliesWithoutSources>None</ExcludeAssembliesWithoutSources>

    <!-- Include only Whizbang production assemblies in coverage -->
    <ModulePaths>
      <Exclude>
        <!-- Test infrastructure -->
        <ModulePath>.*\.Tests\.dll$</ModulePath>
        <ModulePath>.*\.Testing\.dll$</ModulePath>
        <!-- Mocking and test frameworks -->
        <ModulePath>.*Rocks.*</ModulePath>
        <ModulePath>.*Bogus.*</ModulePath>
        <ModulePath>.*TUnit.*</ModulePath>
        <ModulePath>.*Microsoft\.Testing\..*</ModulePath>
        <!-- Framework and third-party -->
        <ModulePath>.*Microsoft\.Extensions\..*</ModulePath>
        <ModulePath>.*System\..*</ModulePath>
      </Exclude>
    </ModulePaths>

    <!-- Exclude compiler-generated attributes from coverage analysis -->
    <Attributes>
      <Exclude>
        <Attribute>^System\.Diagnostics\.DebuggerHiddenAttribute$</Attribute>
        <Attribute>^System\.Diagnostics\.CodeAnalysis\.ExcludeFromCodeCoverageAttribute$</Attribute>
        <Attribute>^System\.CodeDom\.Compiler\.GeneratedCodeAttribute$</Attribute>
      </Exclude>
    </Attributes>
  </CodeCoverage>
</Configuration>
