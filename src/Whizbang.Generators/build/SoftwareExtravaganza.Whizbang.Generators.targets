<Project>
  <!-- Whizbang Message Registry: extract JSON from generated C# (cross-platform) -->
  <UsingTask TaskName="WhizbangExtractMessageRegistryJson" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <SourceFile ParameterType="System.String" Required="true" />
      <OutputFile ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Code Type="Fragment" Language="cs">
        <![CDATA[
        var content = File.ReadAllText(SourceFile);
        var marker = "internal const string Json = @\"";
        var start = content.IndexOf(marker);
        if (start < 0) {
            Log.LogError("Could not find JSON marker in " + SourceFile);
            return false;
        }
        start += marker.Length;
        var end = content.IndexOf("\";", start);
        if (end < 0) {
            Log.LogError("Could not find end of JSON string in " + SourceFile);
            return false;
        }
        var json = content.Substring(start, end - start).Replace("\"\"", "\"");

        var outputDir = Path.GetDirectoryName(OutputFile);
        if (!Directory.Exists(outputDir)) {
            Directory.CreateDirectory(outputDir);
        }

        File.WriteAllText(OutputFile, json);
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <!-- Post-build task to extract message registry JSON from generated C# file -->
  <Target Name="WhizbangExtractMessageRegistry" AfterTargets="Build" Condition="'$(WhizbangEmitMessageRegistry)' == 'true'">
    <PropertyGroup>
      <WhizbangDir>$(MSBuildProjectDirectory)/.whizbang</WhizbangDir>
      <WhizbangGeneratedCSharpFile>$(CompilerGeneratedFilesOutputPath)/Whizbang.Generators/Whizbang.Generators.MessageRegistryGenerator/MessageRegistry.g.cs</WhizbangGeneratedCSharpFile>
      <WhizbangRegistryJsonFile>$(WhizbangDir)/message-registry.json</WhizbangRegistryJsonFile>
    </PropertyGroup>

    <!-- Extract JSON from generated C# file (cross-platform) -->
    <WhizbangExtractMessageRegistryJson
      SourceFile="$(WhizbangGeneratedCSharpFile)"
      OutputFile="$(WhizbangRegistryJsonFile)"
      Condition="Exists('$(WhizbangGeneratedCSharpFile)')" />

    <Message
      Text="Whizbang: Message registry extracted to $(WhizbangRegistryJsonFile)"
      Importance="high"
      Condition="Exists('$(WhizbangRegistryJsonFile)')" />
  </Target>
</Project>
