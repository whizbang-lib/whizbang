<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <Description>Core types, interfaces, and messaging infrastructure for building event-driven, CQRS, and event-sourced applications with zero reflection and AOT compatibility.</Description>
    <RootNamespace>Whizbang.Core</RootNamespace>
    <IsTrimmable>true</IsTrimmable>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <EnableSingleFileAnalyzer>true</EnableSingleFileAnalyzer>
    <!-- Emit source-generated files to disk for debugging -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>$(MSBuildProjectDirectory)/.whizbang-generated</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>
  <!-- Regenerate banner data if the generated file is missing (requires Python 3 + Pillow) -->
  <Target Name="GenerateBannerData" BeforeTargets="CoreCompile"
          Condition="!Exists('$(MSBuildProjectDirectory)/Diagnostics/WhizbangBanner.Generated.cs')">
    <Exec Command="pwsh -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildProjectDirectory)/../../scripts/Build-Logo.ps1&quot;"
          WorkingDirectory="$(MSBuildProjectDirectory)/../.."
          IgnoreExitCode="true"
          StandardOutputImportance="Low" />
  </Target>
  <!-- Include message registry in NuGet package - added dynamically after build generates it -->
  <Target Name="IncludeMessageRegistryInPack" BeforeTargets="GenerateNuspec" DependsOnTargets="WhizbangExtractMessageRegistry">
    <ItemGroup Condition="Exists('$(MSBuildProjectDirectory)/.whizbang/message-registry.json')">
      <None Include="$(MSBuildProjectDirectory)/.whizbang/message-registry.json" Pack="true" PackagePath="contentFiles/any/any/.whizbang/">
        <PackageCopyToOutput>true</PackageCopyToOutput>
      </None>
    </ItemGroup>
  </Target>
  <ItemGroup>
    <PackageReference Include="Medo.Uuid7" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>
  <ItemGroup>
    <!-- Reference source generators for build-time code generation -->
    <ProjectReference Include="../Whizbang.Generators/Whizbang.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>
</Project>