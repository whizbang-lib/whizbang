<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- Unit: Fast tests, no external infrastructure needed -->
    <WhizbangTestType>Unit</WhizbangTestType>
    <!-- Suppress CA1707: Test method names use underscores for readability (Given_When_Then pattern) -->
    <NoWarn>$(NoWarn);CA1707</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="TUnit" />
    <PackageReference Include="TUnit.Assertions" />
    <PackageReference Include="Microsoft.AspNetCore.TestHost" />
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Whizbang.Hosting.AspNet/Whizbang.Hosting.AspNet.csproj" />
    <ProjectReference Include="../../src/Whizbang.Core/Whizbang.Core.csproj" />
  </ItemGroup>
</Project>
