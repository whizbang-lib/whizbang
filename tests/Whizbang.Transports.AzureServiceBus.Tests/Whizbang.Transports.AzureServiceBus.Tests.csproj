<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- Integration: Requires Azure Service Bus Emulator via Testcontainers -->
    <WhizbangTestType>Integration</WhizbangTestType>
    <!-- Tags for filtering: AzureServiceBus, Docker, Messaging -->
    <WhizbangTestTags>AzureServiceBus;Docker;Messaging</WhizbangTestTags>
    <!-- Suppress TUnit0015: Missing CancellationToken parameter (tests use class-level Timeout) -->
    <!-- Suppress TUnit0023: Method should be async (some test patterns are synchronous) -->
    <NoWarn>$(NoWarn);TUnit0015;TUnit0023</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Rocks" />
    <PackageReference Include="TUnit" />
    <PackageReference Include="TUnit.Assertions" />
    <PackageReference Include="Microsoft.Testing.Extensions.CodeCoverage" />
    <PackageReference Include="Azure.Messaging.ServiceBus" />
    <PackageReference Include="Microsoft.Extensions.Diagnostics.HealthChecks" />
    <PackageReference Include="Testcontainers.ServiceBus" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Whizbang.Core/Whizbang.Core.csproj" />
    <ProjectReference Include="../../src/Whizbang.Transports.AzureServiceBus/Whizbang.Transports.AzureServiceBus.csproj" />
    <ProjectReference Include="../../src/Whizbang.Testing/Whizbang.Testing.csproj" />
    <ProjectReference Include="../../src/Whizbang.Generators/Whizbang.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

</Project>
