        CancellationToken cancellationToken = default) {

      // Capture context before dispatching
      CapturedUserId = messageContext.UserId;
      CapturedTenantId = messageContext.TenantId;

      // Dispatch nested command (should inherit security context)
      await dispatcher.SendAsync(new NestedCommand(message.Value), cancellationToken);
