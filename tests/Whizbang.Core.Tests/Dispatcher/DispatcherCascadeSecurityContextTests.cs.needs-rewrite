      IMessageContext messageContext)
      : IReceptor<TestCommand, TestEvent> {

    public ValueTask<TestEvent> HandleAsync(
        TestCommand message,
        CancellationToken cancellationToken = default) {

      // Capture context for verification
      CapturedUserId = messageContext.UserId;
      CapturedTenantId = messageContext.TenantId;

      return ValueTask.FromResult(new TestEvent(message.Value));
    }

    public static string? CapturedUserId { get; set; }
    public static string? CapturedTenantId { get; set; }

    public static void Reset() {
      CapturedUserId = null;
      CapturedTenantId = null;
    }
  }

