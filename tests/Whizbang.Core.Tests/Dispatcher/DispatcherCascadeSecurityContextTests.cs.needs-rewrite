  private IServiceProvider _serviceProvider = null!;
  private IDispatcher _dispatcher = null!;

  [Before(Test)]
  public async Task SetupAsync() {
    // Reset all static captures
    TestCommandHandlerReturningEvent.Reset();
    TestEventReceptor1.Reset();
    TestEventReceptor2.Reset();
    TestEventReceptor3.Reset();
    NestedDispatchingReceptor.Reset();
    NestedCommandHandler.Reset();
    ThrowingReceptor.Reset();

    // Build service provider with Whizbang
    var services = new ServiceCollection();

    services.AddWhizbang()
        .AddLocalDispatcher();

    // Register test receptors
    services.AddScoped<IReceptor<TestCommand, TestEvent>, TestCommandHandlerReturningEvent>();
    services.AddScoped<IReceptor<TestEvent>, TestEventReceptor1>();
    services.AddScoped<IReceptor<TestEvent>, TestEventReceptor2>();
    services.AddScoped<IReceptor<TestEvent>, TestEventReceptor3>();
    services.AddScoped<IReceptor<TestEvent>, NestedDispatchingReceptor>();
    services.AddScoped<IReceptor<NestedCommand, NestedEvent>, NestedCommandHandler>();
    services.AddScoped<IReceptor<TestEvent>, ThrowingReceptor>();

    _serviceProvider = services.BuildServiceProvider();
    _dispatcher = _serviceProvider.GetRequiredService<IDispatcher>();

    await Task.CompletedTask;
  }

  [After(Test)]
  public async Task CleanupAsync() {
    if (_serviceProvider is IAsyncDisposable asyncDisposable) {
      await asyncDisposable.DisposeAsync();
    } else if (_serviceProvider is IDisposable disposable) {
      disposable.Dispose();
    }
  }

