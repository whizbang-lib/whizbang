/// <summary>
/// Tests for security context propagation through cascade paths.
/// Ensures that GetUntypedReceptorPublisher properly establishes security context
/// from source envelopes before invoking receptors.
/// </summary>
/// <docs>core-concepts/message-security#security-context-in-event-cascades</docs>
public class DispatcherCascadeSecurityContextTests {
  // Test message types
  public record TestCommand([property: StreamId] string Value) : ICommand;
  public record TestEvent([property: StreamId] string Value) : IEvent;
  public record NestedCommand([property: StreamId] string Value) : ICommand;
  public record NestedEvent([property: StreamId] string Value) : IEvent;
  public record UnhandledEvent([property: StreamId] string Value) : IEvent;

  // Test receptors
