  [Test]
  public async Task PublishToReceptorsUntyped_WithCancellationToken_PassesToHandleAsyncAsync() {
    // This test verifies cancellation token is passed to receptor HandleAsync

    // Arrange: Custom receptor that captures cancellation token
    CancellationToken? capturedToken = null;

    var services = new ServiceCollection();
    services.AddWhizbang().AddLocalDispatcher();
    services.AddScoped<IReceptor<TestCommand, TestEvent>, TestCommandHandlerReturningEvent>();
    services.AddScoped<IReceptor<TestEvent>>(sp => {
      return new TestEventReceptorCapturingCancellationToken(
          token => capturedToken = token);
    });

    using var provider = services.BuildServiceProvider();
    var dispatcher = provider.GetRequiredService<IDispatcher>();

    var cts = new CancellationTokenSource();

    // Act: Dispatch with cancellation token
    await dispatcher
        .AsSystem()
        .SendAsync<TestCommand, TestEvent>(new TestCommand("test"), cts.Token);

    // Assert: Receptor should receive the cancellation token
    await Assert.That(capturedToken).IsNotNull();
    await Assert.That(capturedToken!.Value.CanBeCanceled).IsTrue();
  }

  private class TestEventReceptorCapturingCancellationToken(
      Action<CancellationToken> captureAction)
      : IReceptor<TestEvent> {

    public ValueTask HandleAsync(TestEvent message, CancellationToken cancellationToken = default) {
      captureAction(cancellationToken);
      return ValueTask.CompletedTask;
    }
  }
