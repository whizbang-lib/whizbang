  // Helper classes for scope tracking
  private class TrackingServiceScopeFactory(
      IServiceScopeFactory innerFactory,
      Action onDispose) : IServiceScopeFactory {

    public IServiceScope CreateScope() {
      var innerScope = innerFactory.CreateScope();
      return new TrackingServiceScope(innerScope, onDispose);
    }
  }

  private class TrackingServiceScope(
      IServiceScope innerScope,
      Action onDispose) : IServiceScope {

    public IServiceProvider ServiceProvider => innerScope.ServiceProvider;

    public void Dispose() {
      onDispose();
      innerScope.Dispose();
    }
  }

  private class AsyncDisposableTrackingScopeFactory(
      IServiceScopeFactory innerFactory,
      Action onDisposeAsync,
      Action onDispose) : IServiceScopeFactory {

    public IServiceScope CreateScope() {
      var innerScope = innerFactory.CreateScope();
      return new AsyncDisposableTrackingScope(innerScope, onDisposeAsync, onDispose);
    }
  }

  private class AsyncDisposableTrackingScope(
      IServiceScope innerScope,
      Action onDisposeAsync,
      Action onDispose) : IServiceScope, IAsyncDisposable {

    public IServiceProvider ServiceProvider => innerScope.ServiceProvider;

    public async ValueTask DisposeAsync() {
      onDisposeAsync();
      if (innerScope is IAsyncDisposable asyncDisposable) {
        await asyncDisposable.DisposeAsync();
      }
    }

    public void Dispose() {
      onDispose();
      innerScope.Dispose();
    }
  }

  private class SyncDisposableTrackingScopeFactory(
      IServiceScopeFactory innerFactory,
      Action onDispose) : IServiceScopeFactory {

    public IServiceScope CreateScope() {
      var innerScope = innerFactory.CreateScope();
      return new SyncDisposableTrackingScope(innerScope, onDispose);
    }
  }

  private class SyncDisposableTrackingScope(
      IServiceScope innerScope,
      Action onDispose) : IServiceScope {

    public IServiceProvider ServiceProvider => innerScope.ServiceProvider;

    public void Dispose() {
      onDispose();
      innerScope.Dispose();
    }
  }

