    // Act: Dispatch command (receptor throws)
    try {
      await dispatcher
          .AsSystem()
          .SendAsync<TestCommand, TestEvent>(command);
    } catch {
      // Expected
    }

    // Assert: Scope should still be disposed
    await Assert.That(scopeDisposed).IsTrue();
  }

