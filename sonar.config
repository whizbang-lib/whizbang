# Shared Sonar configuration — single source of truth for CI and local
# Used by: CI (reusable-quality.yml), local (Run-LocalSonarAnalysis.ps1, Run-PR.ps1)
# Format: one property per line, key=value (lines starting with # are ignored)

# Code analysis exclusions (not analyzed at all)
sonar.exclusions=**/samples/**,**/benchmarks/**,**/tools/**,**/node_modules/**,**/*Generated.cs,**/.whizbang-generated/**

# Copy-paste detection exclusions
sonar.cpd.exclusions=**/tests/**,**/tools/**,**/samples/**,**/benchmarks/**,src/Whizbang.Generators/**,src/Whizbang.Generators.Shared/**,src/Whizbang.Data.EFCore.Postgres.Generators/**,src/Whizbang.Transports.HotChocolate.Generators/**,src/Whizbang.Transports.FastEndpoints.Generators/**,**/EFCorePostgresLensQuery.cs,**/*.sql

# Issue ignore: RCS1118 (mark as const) conflicts with TUnit's TUnitAssertions0005
# (Assert.That must not be used with constant value). Cannot satisfy both in test code.
sonar.issue.ignore.multicriteria=t1,t2,t3,t4,t5,t6,t7,t8
sonar.issue.ignore.multicriteria.t1.ruleKey=external_roslyn:RCS1118
sonar.issue.ignore.multicriteria.t1.resourceKey=**/tests/**
# RCS1163 in tests: unused params are common in test fakes/mocks matching interface signatures
sonar.issue.ignore.multicriteria.t2.ruleKey=external_roslyn:RCS1163
sonar.issue.ignore.multicriteria.t2.resourceKey=**/tests/**
# RCS1021 in tests: lambda→method group conversion conflicts with Assert.That(() => ...) patterns
sonar.issue.ignore.multicriteria.t3.ruleKey=external_roslyn:RCS1021
sonar.issue.ignore.multicriteria.t3.resourceKey=**/tests/**
# RCS1251 in tests: record brace style is preference, not a defect (78 issues, 0 in src)
sonar.issue.ignore.multicriteria.t4.ruleKey=external_roslyn:RCS1251
sonar.issue.ignore.multicriteria.t4.resourceKey=**/tests/**
# IDE0060 in tests: unused params in test fakes (overlaps RCS1163)
sonar.issue.ignore.multicriteria.t5.ruleKey=external_roslyn:IDE0060
sonar.issue.ignore.multicriteria.t5.resourceKey=**/tests/**
# RCS1261 in tests: resource disposal style (49 issues, 0 in src)
sonar.issue.ignore.multicriteria.t6.ruleKey=external_roslyn:RCS1261
sonar.issue.ignore.multicriteria.t6.resourceKey=**/tests/**
# CA2016 in tests: CancellationToken forwarding in test code (46 issues, 0 in src)
sonar.issue.ignore.multicriteria.t7.ruleKey=external_roslyn:CA2016
sonar.issue.ignore.multicriteria.t7.resourceKey=**/tests/**
# CA1873 in tests: string.StartsWith char overload (26 issues, 0 in src)
sonar.issue.ignore.multicriteria.t8.ruleKey=external_roslyn:CA1873
sonar.issue.ignore.multicriteria.t8.resourceKey=**/tests/**

# Coverage exclusions (not measured for coverage — only test/tool/sample/generator code)
sonar.coverage.exclusions=**/samples/**,**/benchmarks/**,**/tests/**,**/tools/**,src/Whizbang.Generators/**,src/Whizbang.Generators.Shared/**,src/Whizbang.Data.EFCore.Postgres.Generators/**,src/Whizbang.Transports.HotChocolate.Generators/**,src/Whizbang.Transports.FastEndpoints.Generators/**
