# Shared Sonar configuration — single source of truth for CI and local
# Used by: CI (reusable-quality.yml), local (Run-LocalSonarAnalysis.ps1, Run-PR.ps1)
# Format: one property per line, key=value (lines starting with # are ignored)

# Code analysis exclusions (not analyzed at all)
sonar.exclusions=**/samples/**,**/benchmarks/**,**/tools/**,**/node_modules/**,**/*Generated.cs,**/.whizbang-generated/**

# Copy-paste detection exclusions
sonar.cpd.exclusions=**/tests/**,**/tools/**,**/samples/**,**/benchmarks/**,src/Whizbang.Generators/**,src/Whizbang.Generators.Shared/**,src/Whizbang.Data.EFCore.Postgres.Generators/**,src/Whizbang.Transports.HotChocolate.Generators/**,src/Whizbang.Transports.FastEndpoints.Generators/**,**/EFCorePostgresLensQuery.cs,**/*.sql

# No issue ignore rules — all issues must be fixed, not suppressed

# Coverage exclusions (not measured for coverage — only test/tool/sample/generator code)
sonar.coverage.exclusions=**/samples/**,**/benchmarks/**,**/tests/**,**/tools/**,src/Whizbang.Generators/**,src/Whizbang.Generators.Shared/**,src/Whizbang.Data.EFCore.Postgres.Generators/**,src/Whizbang.Transports.HotChocolate.Generators/**,src/Whizbang.Transports.FastEndpoints.Generators/**
