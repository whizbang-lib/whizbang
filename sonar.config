# Shared Sonar configuration — single source of truth for CI and local
# Used by: CI (reusable-quality.yml), local (Run-LocalSonarAnalysis.ps1, Run-PR.ps1)
# Format: one property per line, key=value (lines starting with # are ignored)

# Code analysis exclusions (not analyzed at all)
sonar.exclusions=**/samples/**,**/benchmarks/**,**/tools/**,**/node_modules/**,**/*Generated.cs,**/.whizbang-generated/**

# Copy-paste detection exclusions
sonar.cpd.exclusions=**/tests/**,**/tools/**,**/samples/**,**/benchmarks/**,src/Whizbang.Generators/**,src/Whizbang.Generators.Shared/**,src/Whizbang.Data.EFCore.Postgres.Generators/**,src/Whizbang.Transports.HotChocolate.Generators/**,src/Whizbang.Transports.FastEndpoints.Generators/**,**/EFCorePostgresLensQuery.cs,**/*.sql

# Issue ignore rules (suppress specific rules in specific paths)
# Format: sonar.issue.ignore.multicriteria=key1,key2,...
# Then: sonar.issue.ignore.multicriteria.key1.ruleKey=rule
#        sonar.issue.ignore.multicriteria.key1.resourceKey=path
sonar.issue.ignore.multicriteria=e1,e2,e3,e4,e5,e6
sonar.issue.ignore.multicriteria.e1.ruleKey=csharpsquid:S1192
sonar.issue.ignore.multicriteria.e1.resourceKey=src/Whizbang.Generators/**
sonar.issue.ignore.multicriteria.e2.ruleKey=csharpsquid:S1192
sonar.issue.ignore.multicriteria.e2.resourceKey=src/Whizbang.Generators.Shared/**
sonar.issue.ignore.multicriteria.e3.ruleKey=csharpsquid:S1192
sonar.issue.ignore.multicriteria.e3.resourceKey=src/Whizbang.Data.EFCore.Postgres.Generators/**
sonar.issue.ignore.multicriteria.e4.ruleKey=csharpsquid:S1192
sonar.issue.ignore.multicriteria.e4.resourceKey=src/Whizbang.Data.Schema/Schemas/**
sonar.issue.ignore.multicriteria.e5.ruleKey=csharpsquid:S6444
sonar.issue.ignore.multicriteria.e5.resourceKey=src/Whizbang.Generators.Shared/**
sonar.issue.ignore.multicriteria.e6.ruleKey=csharpsquid:S3776
sonar.issue.ignore.multicriteria.e6.resourceKey=src/Whizbang.Generators/**

# Coverage exclusions (not measured for coverage)
sonar.coverage.exclusions=**/samples/**,**/benchmarks/**,**/tests/**,**/tools/**,src/Whizbang.Generators/**,src/Whizbang.Generators.Shared/**,src/Whizbang.Data.Schema/**,src/Whizbang.Data.EFCore.Postgres.Generators/**,src/Whizbang.Transports.HotChocolate.Generators/**,src/Whizbang.Transports.FastEndpoints.Generators/**,src/Whizbang.Hosting.Azure.ServiceBus/**,src/Whizbang.Hosting.RabbitMQ/**,src/Whizbang.Data.Dapper.Postgres/**,src/Whizbang.Transports.RabbitMQ/**,src/Whizbang.Data.EFCore.Postgres/**,src/Whizbang.Transports.AzureServiceBus/**,src/Whizbang.Data.Dapper.Sqlite/**,src/Whizbang.Data.Dapper.Custom/**,src/Whizbang.Data.EFCore.Custom/**,src/Whizbang.Data.Postgres/**,src/Whizbang.Testing/**,src/Whizbang.Observability/**,src/Whizbang.SignalR/**
